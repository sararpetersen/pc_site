---
import MainLayout from "../layouts/MainLayout.astro";

const galleryImages = [
  { src: "/images/desktop-setup.webp", alt: "Computer setup" },
  { src: "/images/intel-chip.webp", alt: "Computer chip" },
  { src: "/images/macbook.webp", alt: "Halv-lukket MacBook" },
  { src: "/images/code.webp", alt: "Kode på skærm" },
  { src: "/images/apple-84.webp", alt: "Gammel Apple computer" },
  { src: "/images/keyboard.webp", alt: "Computer keyboard" },
  { src: "/images/processor.webp", alt: "Processor" },
  { src: "/images/computer-old.webp", alt: "Vintage computere" },
];
---

<MainLayout
  title="Galleri · Computere | Revamped"
  description="Udforsk historien, teknologien og hverdagsbrugen af computere samlet i én tydelig introduktion."
  ogtitle="Galleri · Computere | Revamped"
  ogdescription="Udforsk historien, teknologien og hverdagsbrugen af computere samlet i én tydelig introduktion."
>
  <article class="space-y-10">
    <section class="animate-up rounded-3xl border border-slate-800 bg-slate-900/50 p-7 md:p-10">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-400">Galleri</p>
      <h1 class="mt-3 text-4xl font-bold leading-tight text-white md:text-5xl">Udseende og detaljer</h1>
      <p class="mt-4 max-w-3xl text-slate-300">
        Computerdesign varierer meget&mdash; fra retro-maskiner til moderne setups. Her kan du sammenligne former, materialer og detaljer på tværs af
        billeder.
      </p>
    </section>

    <section class="stagger-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        galleryImages.map((image) => (
          <figure class="hover-lift overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/40">
            <img src={image.src} alt={image.alt} class="h-60 w-full object-cover" loading="lazy" />
            <figcaption class="px-4 py-3 text-sm text-slate-300">{image.alt}</figcaption>
          </figure>
        ))
      }
    </section>
  </article>
</MainLayout>
