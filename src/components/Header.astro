---
const pathname = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Forside" },
  { href: "/min_computer", label: "Min computer" },
  { href: "/operativsystemer", label: "Operativsystemer" },
  { href: "/komponenter", label: "Komponenter" },
  { href: "/galleri", label: "Galleri" },
];
---

<div class="fixed inset-x-0 top-0 z-50 border-b border-slate-800/80 bg-slate-950/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-3 md:flex-row md:items-center md:justify-between md:px-8 md:py-4">
    <a href="/" class="inline-flex items-center gap-2 text-lg font-semibold tracking-tight text-white">
      <img src="/favicon.svg?v=2" alt="Computere logo" class="h-7 w-7 object-contain" />
      <span>Computere</span>
    </a>

    <nav aria-label="Hovednavigation">
      <ul class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-300 md:justify-end">
        {
          navLinks.map((link) => {
            const isActive = pathname === link.href || pathname === `${link.href}/`;
            return (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive ? "page" : undefined}
                  class:list={["rounded-md px-2 py-1 transition", isActive ? "text-white underline underline-offset-4" : "hover:text-white"]}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</div>
